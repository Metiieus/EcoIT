datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// SQLite doesnt support Enums natively in Prisma
// We use String instead for GroupType

model MacroPillar {
  id    String          @id // IDs fixos: "p1" a "p8"
  num   String // "01" a "08"
  name  String // Nome completo do pilar
  short String // Nome curto para pílulas e tags visuais
  color String // Hexadecimal da cor de acento (ex.: #10B981)
  icon  String // Identificador do ícone SVG
  group String // Grupo funcional (infra, gov, sec, biz) - changed to String since SQLite enum support can be tricky sometimes, but the user plan uses GroupType enum. I will stick to String for SQLite as enums aren't natively supported in SQLite. Wait, Prisma supports enums via string in SQLite? Actually, Prisma does not support enums in SQLite. I will use String.
  nodes EcosystemNode[]
}

model EcosystemNode {
  id       String      @id @default(uuid())
  pillarId String
  pillar   MacroPillar @relation(fields: [pillarId], references: [id])
  name     String
  group    String // Enum workaround for SQLite

  // Coordenadas espaciais persistentes para o React Flow
  positionX Float @default(100.0)
  positionY Float @default(100.0)

  // Campo dinâmico para os atributos variáveis dos 4 grupos de TI (JSONB ou String JSON)
  metadata String @default("{}") // Armazena: hwType, ip, status, demandType, resp, prazo, prioridade, dominio, criticidade, tipo, fornecedor, custo

  notes String? // Conteúdo da Wiki & Checkup em Markdown

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vaults    SecretVault[]
  edgesFrom TopologyEdge[] @relation("EdgeSource")
  edgesTo   TopologyEdge[] @relation("EdgeTarget")
}

model TopologyEdge {
  id       String @id @default(uuid())
  sourceId String
  targetId String
  kind     String @default("manual") // "spine", "auto" ou "manual"

  source EcosystemNode @relation("EdgeSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target EcosystemNode @relation("EdgeTarget", fields: [targetId], references: [id], onDelete: Cascade)
}

model SecretVault {
  id     String        @id @default(uuid())
  nodeId String
  node   EcosystemNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  usernameOrToken   String?
  encryptedPassword String // Texto cifrado via AES-256-GCM
  iv                String // Vetor de inicialização (Hexadecimal)
  authTag           String // Tag de autenticação GCM (Hexadecimal)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
