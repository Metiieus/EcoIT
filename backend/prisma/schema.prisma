datasource db {
  provider = "sqlite"
  url      = "file:./ecoit-dev.db"
}

generator client {
  provider = "prisma-client-js"
}

// Nossa única entidade para testar o MVP
model Node {
  id        String   @id @default(uuid())
  
  // A "Casca" do item (O que é igual para todos)
  name      String   // Ex: "Antena Galpão", "Projeto IA", "MikroTik"
  category  String   // Ex: "infra", "gov", "sec", "biz"
  
  // Posição no Canvas do React Flow
  positionX Float    @default(0.0)
  positionY Float    @default(0.0)

  // O "Coração Flexível" - Aqui guardamos o JSON transformado em texto
  // No SQLite usamos String, se migrarmos pro Postgres, mudamos para Jsonb
  metadata  String   @default("{}") 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}